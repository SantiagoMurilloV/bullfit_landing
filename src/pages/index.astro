    <script>
      /* CURSOR */
      const cur = document.getElementById("cur")!;
      const ring = document.getElementById("cur-ring")!;
      let mx = 0,
        my = 0,
        rx = 0,
        ry = 0;
      document.addEventListener("mousemove", (e) => {
        mx = e.clientX;
        my = e.clientY;
        cur.style.left = mx + "px";
        cur.style.top = my + "px";
      });
      (function tick() {
        rx += (mx - rx) * 0.11;
        ry += (my - ry) * 0.11;
        ring.style.left = rx + "px";
        ring.style.top = ry + "px";
        requestAnimationFrame(tick);
      })();
      if ("ontouchstart" in window) {
        cur.style.display = "none";
        ring.style.display = "none";
        document.body.style.cursor = "auto";
      }

      /* NAVBAR */
      const nav = document.getElementById("nav")!;
      window.addEventListener(
        "scroll",
        () => nav.classList.toggle("solid", scrollY > 40),
        { passive: true },
      );

      /* MOBILE MENU */
      const mob = document.getElementById("mob")! as HTMLElement;
      const mobBg = document.getElementById("mob-bg")! as HTMLElement;
      const hbg = document.getElementById("hbg")!;
      const mobClose = document.getElementById("mob-close");
      const b1 = document.getElementById("b1")! as HTMLElement;
      const b2 = document.getElementById("b2")! as HTMLElement;
      const b3 = document.getElementById("b3")! as HTMLElement;
      let open = false;

      function openMenu() {
        open = true;
        mob.style.transform = "translateX(0)";
        mobBg.style.background = "rgba(0,0,0,.55)";
        mobBg.style.pointerEvents = "auto";
        b1.style.transform = "rotate(45deg) translate(5px,5px)";
        b2.style.opacity = "0";
        b3.style.transform = "rotate(-45deg) translate(5px,-5px)";
        document.body.style.overflow = "hidden";
      }
      function closeMenu() {
        open = false;
        mob.style.transform = "translateX(100%)";
        mobBg.style.background = "rgba(0,0,0,0)";
        mobBg.style.pointerEvents = "none";
        b1.style.transform = b3.style.transform = "";
        b2.style.opacity = "1";
        document.body.style.overflow = "";
      }

      hbg.addEventListener("click", () => (open ? closeMenu() : openMenu()));
      mobBg.addEventListener("click", closeMenu);
      mobClose?.addEventListener("click", closeMenu);
      mob
        .querySelectorAll("[data-mob]")
        .forEach((el) => el.addEventListener("click", closeMenu));

      /* SCROLL REVEAL */
      const io = new IntersectionObserver(
        (entries) => {
          entries.forEach((e) => {
            if (e.isIntersecting) e.target.classList.add("on");
          });
        },
        { threshold: 0.07, rootMargin: "0px 0px -36px 0px" },
      );
      document.querySelectorAll(".sr,.sl,.srr").forEach((el) => io.observe(el));

      /* PARALLAX ORBS */
      window.addEventListener(
        "mousemove",
        (e) => {
          const x = e.clientX / innerWidth - 0.5,
            y = e.clientY / innerHeight - 0.5;
          const o1 = document.getElementById("ob1"),
            o2 = document.getElementById("ob2");
          if (o1) o1.style.transform = `translate(${x * 26}px,${y * 16}px)`;
          if (o2) o2.style.transform = `translate(${-x * 16}px,${-y * 12}px)`;
        },
        { passive: true },
      );

      /* FORM — envía la consulta al administrador como JSON */
      // 👇 PEGA AQUÍ LA URL DEL ENDPOINT cuando la tengas (ej: 'https://...').
      const FORM_ENDPOINT = "";

      document
        .getElementById("cform")
        ?.addEventListener("submit", async (e) => {
          e.preventDefault();
          const form = e.currentTarget as HTMLFormElement;
          const btn = document.getElementById("sbtn") as HTMLButtonElement;
          const msg = document.getElementById("cform-msg") as HTMLElement;

          const fd = new FormData(form);
          const payload = {
            nombre: (fd.get("nombre") || "").toString().trim(),
            apellido: (fd.get("apellido") || "").toString().trim(),
            whatsapp: (fd.get("whatsapp") || "").toString().trim(),
            interes: (fd.get("interes") || "").toString().trim(),
            mensaje: (fd.get("mensaje") || "").toString().trim(),
            fuente: "landing-bullfit",
            fecha: new Date().toISOString(),
          };

          const showMsg = (text: string, color: string) => {
            msg.textContent = text;
            msg.style.color = color;
            msg.classList.remove("hidden");
          };

          if (!payload.nombre || !payload.whatsapp) {
            showMsg("Por favor completa tu nombre y WhatsApp.", "#dc2626");
            return;
          }

          btn.disabled = true;
          const original = btn.textContent;
          btn.textContent = "Enviando…";
          msg.classList.add("hidden");

          try {
            if (!FORM_ENDPOINT) {
              // Endpoint aún no configurado: dejamos el JSON listo en consola.
              console.log(
                "[BullFit] Consulta lista para enviar:",
                JSON.stringify(payload),
              );
              throw new Error("ENDPOINT_PENDIENTE");
            }
            const res = await fetch(FORM_ENDPOINT, {
              method: "POST",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify(payload),
            });
            if (!res.ok) throw new Error("HTTP " + res.status);

            btn.textContent = "¡Enviado!";
            btn.style.background = "#16a34a";
            showMsg(
              "Gracias, te contactaremos pronto por WhatsApp.",
              "#16a34a",
            );
            form.reset();
            setTimeout(() => {
              btn.textContent = original;
              btn.style.background = "";
              btn.disabled = false;
              msg.classList.add("hidden");
            }, 4000);
          } catch (err) {
            btn.textContent = original;
            btn.disabled = false;
            if ((err as Error).message === "ENDPOINT_PENDIENTE") {
              showMsg(
                "Formulario en configuración. Escríbenos por WhatsApp mientras tanto.",
                "#b45309",
              );
            } else {
              showMsg(
                "No se pudo enviar. Intenta de nuevo o escríbenos por WhatsApp.",
                "#dc2626",
              );
            }
          }
        });
    </script>

    <Analytics />

    <!-- Estado Abierto/Cerrado — zona horaria Colombia (America/Bogota) -->
    <script>
      function bullfitIsOpen() {
        // Hora actual en Colombia (UTC-5, sin cambio de horario)
        const now = new Date(
          new Date().toLocaleString("en-US", { timeZone: "America/Bogota" })
        );
        const day = now.getDay();   // 0=Dom, 1=Lun, ..., 6=Sáb
        const h   = now.getHours();
        const m   = now.getMinutes();
        const mins = h * 60 + m;   // minutos desde medianoche

        if (day === 0) return false; // Domingo: cerrado
        if (day >= 1 && day <= 5) {
          // Lun–Vie: 6:00–12:00 y 16:00–19:00
          return (mins >= 360 && mins < 720) || (mins >= 960 && mins < 1140);
        }
        if (day === 6) {
          // Sábado: 9:00–11:00
          return mins >= 540 && mins < 660;
        }
        return false;
      }

      function applyStatus() {
        const open = bullfitIsOpen();
        const color = open ? "#4ade80" : "#f87171"; // green-400 / red-400
        const text  = open ? "Abierto ahora" : "Cerrado";

        ["hero", "footer"].forEach((id) => {
          const dot  = document.getElementById("status-dot-" + id);
          const span = document.getElementById("status-text-" + id);
          if (dot)  dot.style.backgroundColor = color;
          if (span) { span.textContent = text; span.style.color = color; }
        });
      }

      applyStatus();
      // Recalcula cada minuto por si la página queda abierta
      setInterval(applyStatus, 60_000);
    </script>
