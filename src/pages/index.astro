---
import "../styles/global.css";
import Analytics from "@vercel/analytics/astro";

const svg = (paths: string, size = 28) =>
  `<svg xmlns="http://www.w3.org/2000/svg" width="${size}" height="${size}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">${paths}</svg>`;

const icons = {
  users: svg(
    `<path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>`,
  ),
  target: svg(
    `<circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/>`,
  ),
  calendar: svg(
    `<rect width="18" height="18" x="3" y="4" rx="2" ry="2"/><line x1="16" x2="16" y1="2" y2="6"/><line x1="8" x2="8" y1="2" y2="6"/><line x1="3" x2="21" y1="10" y2="10"/>`,
  ),
  dumbbell: svg(
    `<path d="m6.5 6.5 11 11"/><path d="m21 21-1-1"/><path d="m3 3 1 1"/><path d="m18 22 4-4"/><path d="m2 6 4-4"/><path d="m3 10 7-7"/><path d="m14 21 7-7"/>`,
  ),
  eye: svg(
    `<path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"/><circle cx="12" cy="12" r="3"/>`,
  ),
  zap: svg(`<polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>`),
  flame: svg(
    `<path d="M8.5 14.5A2.5 2.5 0 0 0 11 12c0-1.38-.5-2-1-3-1.072-2.143-.224-4.054 2-6 .5 2.5 2 4.9 4 6.5 2 1.6 3 3.5 3 5.5a7 7 0 1 1-14 0c0-1.153.433-2.294 1-3a2.5 2.5 0 0 0 2.5 2.5z"/>`,
  ),
  handshake: svg(
    `<path d="m11 17 2 2a1 1 0 1 0 3-3"/><path d="m14 14 2.5 2.5a1 1 0 1 0 3-3l-3.88-3.88a3 3 0 0 0-4.24 0l-.88.88a1 1 0 1 1-3-3l2.81-2.81a5.79 5.79 0 0 1 7.06-.87l.47.28a2 2 0 0 0 1.42.25L21 4"/><path d="m21 3 1 11h-2"/><path d="M3 3 2 14l6.5 6.5a1 1 0 1 0 3-3"/><path d="M3 4h8"/>`,
  ),
  bike: svg(
    `<circle cx="18.5" cy="17.5" r="3.5"/><circle cx="5.5" cy="17.5" r="3.5"/><circle cx="15" cy="5" r="1"/><path d="M12 17.5V14l-3-3 4-3 2 3h2"/>`,
  ),
  activity: svg(`<polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>`),
  badgeCheck: svg(
    `<path d="M3.85 8.62a4 4 0 0 1 4.78-4.77 4 4 0 0 1 6.74 0 4 4 0 0 1 4.78 4.78 4 4 0 0 1 0 6.74 4 4 0 0 1-4.77 4.78 4 4 0 0 1-6.75 0 4 4 0 0 1-4.78-4.77 4 4 0 0 1 0-6.76Z"/><path d="m9 12 2 2 4-4"/>`,
  ),
  shield: svg(`<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>`),
  mapPin: svg(
    `<path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/>`,
    22,
  ),
  instagram: svg(
    `<rect width="20" height="20" x="2" y="2" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/>`,
    22,
  ),
  clock: svg(
    `<circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>`,
    22,
  ),
  check: svg(`<polyline points="20 6 9 18 4 13"/>`, 12),
  star: svg(
    `<polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2" fill="currentColor" stroke="none"/>`,
    14,
  ),
};
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />

    <!-- ═══ SEO BÁSICO ═══ -->
    <title>
      BullFit Armenia | Entrenamiento Semipersonalizado — Quindío, Colombia
    </title>
    <meta
      name="description"
      content="BullFit: entrenamiento semipersonalizado en Armenia, Quindío. Grupos de máximo 10 personas, atención personalizada, planes desde $10.000. ¡Entrena sin límites!"
    />
    <meta
      name="keywords"
      content="gimnasio Armenia Quindío, entrenamiento personalizado Armenia, BullFit, fitness Armenia Colombia, gym Armenia, clases funcionales Armenia, entrenamiento semipersonalizado Colombia"
    />
    <meta name="robots" content="index, follow" />
    <meta name="author" content="BullFit Armenia" />
    <link rel="canonical" href="https://bullfit.co/" />

    <!-- ═══ OPEN GRAPH (Facebook, WhatsApp, etc.) ═══ -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://bullfit.co/" />
    <meta
      property="og:title"
      content="BullFit Armenia | Entrenamiento Semipersonalizado"
    />
    <meta
      property="og:description"
      content="Grupos de máximo 10 personas en Armenia, Quindío. Atención personalizada, ambiente familiar y resultados reales. Plan día desde $10.000."
    />
    <meta property="og:image" content="https://bullfit.co/brand/og-image.jpg" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content="BullFit Armenia" />
    <meta property="og:locale" content="es_CO" />

    <!-- ═══ TWITTER / X CARD ═══ -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta
      name="twitter:title"
      content="BullFit Armenia | Entrenamiento Semipersonalizado"
    />
    <meta
      name="twitter:description"
      content="Grupos de máximo 10 personas en Armenia, Quindío. Atención personalizada y resultados reales."
    />
    <meta
      name="twitter:image"
      content="https://bullfit.co/brand/og-image.jpg"
    />

    <!-- ═══ GEO / LOCAL SEO ═══ -->
    <meta name="geo.region" content="CO-QUI" />
    <meta name="geo.placename" content="Armenia, Quindío, Colombia" />
    <meta name="geo.position" content="4.5339;-75.6811" />
    <meta name="ICBM" content="4.5339, -75.6811" />

    <!-- ═══ SCHEMA.ORG (JSON-LD) — rich snippets en Google ═══ -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "SportsActivityLocation",
        "name": "BullFit Armenia",
        "description": "Centro de entrenamiento semipersonalizado en Armenia, Quindío. Grupos de máximo 10 personas por sesión.",
        "url": "https://bullfit.co",
        "logo": "https://bullfit.co/brand/logo-badge.png",
        "image": "https://bullfit.co/brand/og-image.jpg",
        "telephone": "+573186011559",
        "address": {
          "@type": "PostalAddress",
          "addressLocality": "Armenia",
          "addressRegion": "Quindío",
          "addressCountry": "CO"
        },
        "geo": {
          "@type": "GeoCoordinates",
          "latitude": 4.5339,
          "longitude": -75.6811
        },
        "openingHoursSpecification": [
          {
            "@type": "OpeningHoursSpecification",
            "dayOfWeek": [
              "Monday",
              "Tuesday",
              "Wednesday",
              "Thursday",
              "Friday"
            ],
            "opens": "06:00",
            "closes": "19:00"
          },
          {
            "@type": "OpeningHoursSpecification",
            "dayOfWeek": ["Saturday"],
            "opens": "09:00",
            "closes": "12:00"
          }
        ],
        "priceRange": "$",
        "sameAs": ["https://www.instagram.com/bullfit.axm/"]
      }
    </script>

    <!-- ═══ FAVICONS ═══ -->
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <!-- ═══ FUENTES ═══ -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Inter:wght@300;400;500;600;700;800;900&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <div id="cur"></div>
    <div id="cur-ring"></div>

    <!-- ════════════════════════════════
  NAVBAR  — dark
════════════════════════════════ -->
    <nav
      id="nav"
      class="fixed top-0 inset-x-0 z-50 px-6 md:px-12 py-[18px] transition-all duration-400"
    >
      <div class="max-w-7xl mx-auto flex items-center justify-between">
        <a href="#" class="group flex items-center gap-2.5">
          <img
            src="/brand/logo-header.png"
            alt="BullFit"
            class="w-8 h-8 shrink-0 object-cover transition-transform duration-300 group-hover:scale-110"
            style="border-radius:5px;box-shadow:0 4px 14px rgba(0,0,0,.55), 0 0 0 1px rgba(0,0,0,.55);"
          />
          <span
            class="font-black tracking-[.14em] text-white"
            style="font-family:'Bebas Neue';font-size:1.1rem;"
          >
            BULL<span style="color:var(--red);">FIT</span>
          </span>
        </a>

        <ul class="hidden md:flex gap-8">
          {
            [
              ["Inicio", "#inicio"],
              ["Metodología", "#metodo"],
              ["Planes", "#planes"],
              ["Contacto", "#contacto"],
            ].map(([l, h]) => (
              <li>
                <a
                  href={h}
                  class="text-[.73rem] font-semibold tracking-[.18em] uppercase text-white/60 hover:text-white transition-colors relative group"
                >
                  {l}
                  <span
                    class="absolute -bottom-0.5 left-0 w-0 h-px group-hover:w-full transition-all duration-300"
                    style="background:var(--red);"
                  />
                </a>
              </li>
            ))
          }
        </ul>

        <button id="hbg" class="md:hidden flex flex-col gap-[5px] p-2">
          <span
            id="b1"
            class="w-6 h-[2px] bg-white rounded transition-all duration-300 origin-center block"
          ></span>
          <span
            id="b2"
            class="w-4 h-[2px] rounded transition-all duration-300 block"
            style="background:var(--red);"></span>
          <span
            id="b3"
            class="w-6 h-[2px] bg-white rounded transition-all duration-300 origin-center block"
          ></span>
        </button>
      </div>
    </nav>

    <!-- mobile backdrop -->
    <div
      id="mob-bg"
      class="fixed inset-0 z-30 pointer-events-none"
      style="background:rgba(0,0,0,0);transition:background .38s ease;"
    >
    </div>

    <!-- mobile drawer -->
    <div
      id="mob"
      class="fixed top-0 right-0 bottom-0 z-40 flex flex-col py-7 px-7"
      style="width:min(280px,84vw);background:rgba(9,9,10,.97);backdrop-filter:blur(32px);border-left:1px solid rgba(255,255,255,.07);transform:translateX(100%);transition:transform .42s cubic-bezier(.16,1,.3,1);"
    >
      <!-- header del drawer -->
      <div class="flex items-center justify-between mb-10">
        <span
          class="font-black tracking-[.14em] text-white"
          style="font-family:'Bebas Neue';font-size:1rem;"
          >BULL<span style="color:var(--red);">FIT</span></span
        >
        <button
          id="mob-close"
          class="w-8 h-8 flex items-center justify-center rounded-lg transition-colors hover:bg-white/10"
          style="background:rgba(255,255,255,.06);"
        >
          <svg
            width="14"
            height="14"
            viewBox="0 0 14 14"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"><path d="M1 1l12 12M13 1L1 13"></path></svg
          >
        </button>
      </div>

      <!-- links -->
      <nav class="flex flex-col flex-1 gap-1">
        {
          [
            ["Inicio", "#inicio"],
            ["Metodología", "#metodo"],
            ["Planes", "#planes"],
            ["Contacto", "#contacto"],
          ].map(([l, h]) => (
            <a
              href={h}
              data-mob
              class="flex items-center justify-between py-4 text-[.75rem] font-semibold tracking-[.18em] uppercase transition-colors hover:text-white"
              style="color:rgba(255,255,255,.48);border-bottom:1px solid rgba(255,255,255,.06);"
            >
              {l}
              <svg
                width="12"
                height="12"
                viewBox="0 0 12 12"
                fill="none"
                stroke="currentColor"
                stroke-width="1.3"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="M1 6h10M7 2l4 4-4 4" />
              </svg>
            </a>
          ))
        }
      </nav>
    </div>

    <!-- ════════════════════════════════
  HERO  — negro
════════════════════════════════ -->
    <section
      id="inicio"
      class="relative min-h-screen flex items-center overflow-hidden noise"
      style="padding-top:80px; background:var(--black);"
    >
      <div class="absolute inset-0 grid-dark"></div>
      <div
        class="absolute inset-0"
        style="background:radial-gradient(ellipse 70% 60% at 15% 60%, rgba(232,0,14,.1), transparent);"
      >
      </div>
      <div
        class="absolute inset-y-0 left-[10%] w-px"
        style="background:linear-gradient(to bottom,transparent,rgba(232,0,14,.25),transparent);"
      >
      </div>

      <!-- toro pixel-art de fondo -->
      <img
        src="/brand/bull-pixel.png"
        alt=""
        aria-hidden="true"
        class="bull-pixel absolute pointer-events-none select-none"
      />

      <div
        id="ob1"
        class="absolute top-1/4 left-[6%] w-80 h-80 rounded-full blur-3xl pointer-events-none"
        style="background:rgba(232,0,14,.06);animation:drift 9s ease-in-out infinite;"
      >
      </div>
      <div
        id="ob2"
        class="absolute bottom-1/4 right-[8%] w-56 h-56 rounded-full blur-3xl pointer-events-none"
        style="background:rgba(200,200,204,.03);animation:drift2 7s ease-in-out infinite 1.5s;"
      >
      </div>

      <div class="relative z-10 max-w-7xl mx-auto px-6 md:px-12 w-full py-16">
        <div class="grid lg:grid-cols-[1fr_420px] gap-16 items-center">
          <!-- texto -->
          <div>
            <div class="h1 flex items-center gap-3 mb-7">
              <span class="w-9 h-[1.5px]" style="background:var(--red);"></span>
              <span
                class="text-[.65rem] font-bold tracking-[.35em] uppercase"
                style="color:var(--red);">Armenia · Quindío</span
              >
            </div>

            <h1
              style="font-family:'Bebas Neue';line-height:.92;margin-bottom:2rem;"
            >
              <div
                class="h1 text-white"
                style="font-size:clamp(4rem,13vw,10.5rem);"
              >
                ENTRENA
              </div>
              <div
                class="h2 whitespace-nowrap"
                style="font-size:clamp(3rem,9.5vw,10.5rem);"
              >
                <span style="color:var(--red);">SIN</span>
                <span class="text-white">LÍMITES</span>
              </div>
            </h1>

            <p
              class="hs leading-relaxed max-w-[460px] mb-10"
              style="color:var(--gray-5);font-size:1.02rem;"
            >
              Entrenamiento <span class="text-white font-semibold"
                >semipersonalizado</span
              > con máximo
              <span class="text-white font-semibold"
                >10 personas por sesión.</span
              > La atención que mereces, la intensidad que buscas.
            </p>

            <div class="hc flex flex-wrap gap-4 mb-12">
              <a href="#planes" class="btn-r">Ver Planes</a>
              <a href="#metodo" class="btn-o">Nuestra Metodología</a>
            </div>

            <!-- stat strip -->
            <div class="hc flex flex-wrap gap-x-8 gap-y-4 items-center">
              {
                [
                  ["100+", "Miembros"],
                  ["10", "Máx/sesión"],
                  ["Lun–Sáb", "Horario"],
                ].map(([n, l]) => (
                  <div class="flex items-center gap-2.5">
                    <span
                      class="font-black text-2xl"
                      style="font-family:'Bebas Neue';color:var(--red);"
                    >
                      {n}
                    </span>
                    <span
                      class="text-[.65rem] uppercase tracking-wider leading-tight"
                      style="color:var(--gray-5);"
                    >
                      {l}
                    </span>
                  </div>
                ))
              }
              <div
                class="w-px h-7 hidden sm:block"
                style="background:var(--gray-3);"
              >
              </div>
              <div class="flex items-center gap-2">
                <div
                  id="status-dot-hero"
                  class="w-1.5 h-1.5 rounded-full bg-green-400"
                  style="animation:drift2 2s ease-in-out infinite;"
                >
                </div>
                <span
                  id="status-text-hero"
                  class="text-[.65rem] uppercase tracking-wider"
                  style="color:var(--gray-5);">Abierto ahora</span
                >
              </div>
            </div>
          </div>

          <!-- holograma del toro (desktop) -->
          <div
            class="hidden lg:flex items-center justify-center relative"
            style="min-height:560px;"
          >
            <div class="holo-stage">
              <div class="holo-cone" aria-hidden="true"></div>
              <div class="holo-glow" aria-hidden="true"></div>
              <!-- proyección difuminada que se desvanece hacia abajo -->
              <img
                src="/brand/bull-pixel.png"
                alt=""
                aria-hidden="true"
                class="holo-bull holo-body"
              />
              <!-- aberración cromática de la cabeza -->
              <img
                src="/brand/bull-pixel.png"
                alt=""
                aria-hidden="true"
                class="holo-bull holo-ghost holo-ghost--c"
              />
              <img
                src="/brand/bull-pixel.png"
                alt=""
                aria-hidden="true"
                class="holo-bull holo-ghost holo-ghost--r"
              />
              <!-- cabeza principal nítida -->
              <img
                src="/brand/bull-pixel.png"
                alt="BullFit"
                class="holo-bull holo-head"
              />
              <div class="holo-scan" aria-hidden="true"></div>
              <div class="holo-base" aria-hidden="true"></div>
            </div>
          </div>
        </div>
      </div>

      <!-- scroll line -->
      <div
        class="absolute bottom-7 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2"
      >
        <div
          class="w-px h-10"
          style="background:linear-gradient(to bottom,var(--red),transparent);animation:drift2 2.5s ease-in-out infinite;"
        >
        </div>
        <span
          class="text-[.58rem] tracking-[.3em] uppercase"
          style="color:var(--gray-3);">Scroll</span
        >
      </div>
    </section>

    <!-- ════════════════════════════════
  MARQUEE  — rojo
════════════════════════════════ -->
    <div class="overflow-hidden py-3.5" style="background:var(--red);">
      <div
        class="marquee font-black tracking-[.22em] uppercase select-none"
        style="font-family:'Bebas Neue';font-size:1rem;color:rgba(0,0,0,.8);"
      >
        {
          Array(20)
            .fill(0)
            .map((_, i) => (
              <span class="mx-8 shrink-0">
                {i % 2 === 0 ? "✦ BULLFIT ARMENIA" : "✦ ENTRENA MÁS DURO"}
              </span>
            ))
        }
      </div>
    </div>

    <!-- grad: red → gray-1 -->
    <div
      class="grad-section"
      style="background:linear-gradient(to bottom,var(--red),var(--gray-1));"
    >
    </div>

    <!-- ════════════════════════════════
  STATS  — gris oscuro
════════════════════════════════ -->
    <section
      class="relative py-20 overflow-hidden"
      style="background:var(--gray-1);"
    >
      <div class="absolute inset-0 grid-dark opacity-60"></div>

      <div class="relative max-w-7xl mx-auto px-6 md:px-12">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
          {
            [
              { n: "100+", l: "Miembros activos", icon: icons.users },
              { n: "10", l: "Máx. por sesión", icon: icons.target },
              {
                n: "Lun–Sáb",
                l: "Click para ver los horarios",
                icon: icons.calendar,
              },
              { n: "100%", l: "Compromiso contigo", icon: icons.dumbbell },
            ].map((s, i) => {
              const isSchedule = i === 2;
              const Tag = isSchedule ? "a" : "div";
              return (
                <Tag
                  href={isSchedule ? "#horarios" : undefined}
                  class={`sr d${i + 1} text-center py-8 rounded-xl ch ch-dark${isSchedule ? " cursor-pointer transition-transform duration-200 hover:-translate-y-1" : ""}`}
                  style={`background:var(--gray-2);border:1px solid var(--gray-3);box-shadow:0 2px 12px rgba(0,0,0,.3),0 1px 3px rgba(0,0,0,.2);${isSchedule ? "display:block;" : ""}`}
                >
                  <div class="flex justify-center mb-5">
                    <div
                      class="w-14 h-14 rounded-2xl flex items-center justify-center"
                      style="background:rgba(232,0,14,.1);border:1px solid rgba(232,0,14,.2);color:var(--red);"
                    >
                      <span set:html={s.icon} />
                    </div>
                  </div>
                  <div
                    class="font-black text-white mb-1.5"
                    style="font-family:'Bebas Neue';font-size:clamp(2.2rem,4vw,3.5rem);line-height:1;"
                  >
                    {s.n}
                  </div>
                  <div
                    class="text-[.65rem] uppercase tracking-[.18em]"
                    style="color:var(--gray-5);"
                  >
                    {s.l}
                  </div>
                </Tag>
              );
            })
          }
        </div>
      </div>
    </section>

    <!-- grad: gray-1 → white -->
    <div
      class="grad-section"
      style="background:linear-gradient(to bottom,var(--gray-1),var(--white));"
    >
    </div>

    <!-- ════════════════════════════════
  METODOLOGÍA  — blanco
════════════════════════════════ -->
    <section
      id="metodo"
      class="relative py-28 overflow-hidden noise"
      style="background:var(--white);"
    >
      <div class="absolute inset-0 grid-light"></div>
      <div class="absolute top-0 inset-x-0 h-1" style="background:var(--red);">
      </div>

      <div class="relative z-10 max-w-7xl mx-auto px-6 md:px-12">
